                        <path class="circle-progress" stroke="#E74C3C" stroke-dasharray="{{Skills_Critical_Thinking}}, 100" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
                    </svg>
                    <div class="circle-text">{{Skills_Critical_Thinking}}%</div>
