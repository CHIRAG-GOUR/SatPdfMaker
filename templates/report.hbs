                <div class="sub-skill"><div class="sub-skill-top"><span>Openness to Change</span><span>{{Sub_Openness_to_Change}}%</span></div><div class="bar-bg"><div class="bar-fill" style="width: {{Sub_Openness_to_Change}}%;"></div></div></div>
            </div>

            <!-- Right Column Cards -->
            <div class="card">
                <div class="card-header">
