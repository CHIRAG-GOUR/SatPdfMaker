<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Report - {{Name}}</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        body { -webkit-print-color-adjust: exact; background: #fff; color: #333; }

        @media screen {
            body {
                background: #e9ecef;
                display: flex;
                flex-direction: column;
                align-items: center;
                padding: 20px 0;
            }
            .page {
                box-shadow: 0 4px 10px rgba(0,0,0,0.15);
                margin-bottom: 15px;
            }
        }

        @page { size: A4; margin: 0; }

        .page {
            width: 210mm;
            height: 297mm;
            max-height: 297mm;
            overflow: hidden;
            page-break-inside: avoid;
            page-break-after: always;
            position: relative;
            background: white;
            display: flex;
            flex-direction: column;
            padding: 12mm; /* reduced padding to prevent cutting */
            box-sizing: border-box;
        }
        .page.cover { padding: 0; }
        .page:last-child { page-break-after: auto; }

        .cover-img { width: 100%; height: 100%; object-fit: cover; }
        .cover-placeholder { width:100%; height:100%; display:flex; align-items:center; justify-content:center; background:#ecf0f1; color:#bdc3c7; font-size:24px; }

        /* General Common */
        h1.section-title {
            text-align: center;
            font-size: 20px;
            color: #2C3E50;
            margin-top: -5px; /* Pulls the heading up to reduce space */
            margin-bottom: 12px;
            font-weight: 700;
        }

        .text-left {
            text-align: left !important;
        }

        h2.sub-title {
            font-size: 16px;
            color: #555;
            margin-bottom: 15px;
            margin-top: 15px;
            border-bottom: 2px solid #E5E8E8;
            padding-bottom: 5px;
        }

        /* --- PAGE 2: SKILLS PROFILE --- */
        /* Circular Progress Grid */
        .circles-grid {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 5px;
            margin-bottom: 12px;
        }
        .circle-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
        }
        .circle-wrapper {
            position: relative;
            width: 60px;
            height: 60px;
            margin-bottom: 5px;
        }
        .circle-wrapper svg { width: 100%; height: 100%; }
        .circle-bg { fill: none; stroke: #EEEEEE; stroke-width: 4; }
        .circle-progress { fill: none; stroke-width: 4; stroke-linecap: round; }
        .circle-text {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            font-size: 15px;
            font-weight: bold;
            color: #333;
        }
        .circle-label { font-size: 11px; font-weight: 600; color: #555; line-height: 1.2; }

        /* Detailed Breakdown Grid */
        .breakdown-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 8px 15px;
            flex-grow: 1; /* Stretch to fill */
        }
        
        .card {
            background: #F8F9F9;
            border-radius: 10px;
            padding: 8px 10px;
            border: 1px solid #E5E8E8;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }
        
        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 5px;
        }
        .card-header-left { display: flex; align-items: center; gap: 8px; font-weight: 700; font-size: 14px; color: #2C3E50; }
        .card-header-right { font-weight: 700; font-size: 15px; color: #2980B9; }

        .sub-skill {
            margin-bottom: 3px;
        }
        .sub-skill:last-child { margin-bottom: 0; }
        .sub-skill-top {
            display: flex;
            justify-content: space-between;
            font-size: 11px;
            color: #555;
            margin-bottom: 2px;
        }
        .bar-bg {
            background: #E5E8E8;
            height: 6px;
            border-radius: 4px;
            width: 100%;
            overflow: hidden;
        }
        .bar-fill {
            height: 100%;
            background: #1e429b;
            border-radius: 4px;
        }

        /* --- PAGE 3: LEARNER PROFILE --- */
        .lp-header { margin-bottom: 15px; text-align: center; }
        .lp-subtitle { font-size: 12px; color: #7F8C8D; margin-bottom: 12px; text-align: center; }
        
        .top-profiles {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 8px;
            margin-bottom: 12px;
        }
        .top-card {
            background: #F0F8FF;
            border: 1px solid #aecce0;
            border-radius: 8px;
            padding: 12px;
            text-align: center;
        }
        .top-card-icon { font-size: 24px; margin-bottom: 2px; }
        .top-card-name { font-size: 15px; font-weight: bold; margin-bottom: 5px; color: #333; }
        .top-card-score { font-size: 20px; font-weight: bold; color: #2C3E50; margin-bottom: 2px; }
        .top-card-badge {
            display: inline-block;
            padding: 3px 10px;
            border-radius: 12px;
            font-size: 10px;
            font-weight: 700;
            margin-bottom: 5px;
        }
        .top-card-desc { 
            font-size: 10px; 
            color: #666; 
            line-height: 1.4; 
            text-align: center; 
            white-space: normal; 
            overflow: hidden; 
            text-overflow: ellipsis; 
        }

        .growth-profiles {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 5px;
            margin-bottom: 15px;
        }
        .growth-card {
            background: #FFFDF0;
            border: 1px solid #F1C40F;
            border-radius: 8px;
            padding: 10px;
            display: flex;
            align-items: flex-start;
            gap: 5px;
        }
        .growth-card-icon { font-size: 20px; }
        .growth-card-content { flex: 1; }
        .growth-card-header { display: flex; align-items: center; gap: 8px; margin-bottom: 2px; }
        .growth-card-name { font-size: 13px; font-weight: bold; color: #333; }
        .growth-card-desc { 
            font-size: 10px; 
            color: #666; 
            line-height: 1.3; 
            white-space: normal; 
            overflow: hidden; 
            text-overflow: ellipsis; 
        }

        .overview-list {
            display: flex;
            flex-direction: column;
            gap: 2px;
        }
        .overview-item {
            display: flex;
            align-items: center;
            border-bottom: 1px solid #aecce0;
            padding-bottom: 6px;
            margin-bottom: 2px;
        }
        .overview-item:last-of-type {
            border-bottom: none;
            padding-bottom: 0;
            margin-bottom: 0;
        }
        .overview-icon { font-size: 16px; width: 25px; }
        .overview-name { font-size: 13px; font-weight: 600; width: 120px; color: #333; }
        .overview-tag { font-size: 9px; padding: 2px 6px; border-radius: 4px; font-weight: bold; margin-right: 8px; background: #eee; min-width: 45px; text-align: center; }
        .overview-bar-container { flex: 1; display: flex; align-items: center; }
        .overview-bar-bg { width: 100%; height: 8px; background: #eee; border-radius: 4px; margin-right: 8px; }
        .overview-bar-fill { height: 100%; background: #1e429b; border-radius: 4px; }
        .overview-score { font-size: 13px; font-weight: 700; width: 65px; text-align: right; display: flex; flex-direction: column; align-items: flex-end; gap: 2px; }

    </style>
</head>
<body>

    <!-- PAGE 1: Front Cover -->
