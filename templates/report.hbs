                        <path class="circle-progress" stroke="#8E44AD" stroke-dasharray="{{Skills_Creative_Thinking}}, 100" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
