                </div>
                <div class="sub-skill"><div class="sub-skill-top"><span>Collaboration</span><span>{{Sub_Collaboration}}%</span></div><div class="bar-bg"><div class="bar-fill" style="width: {{Sub_Collaboration}}%;"></div></div></div>
                <div class="sub-skill"><div class="sub-skill-top"><span>Communication</span><span>{{Sub_Communication}}%</span></div><div class="bar-bg"><div class="bar-fill" style="width: {{Sub_Communication}}%;"></div></div></div>
                <div class="sub-skill"><div class="sub-skill-top"><span>Conflict Resolution</span><span>{{Sub_Conflict_Resolution}}%</span></div><div class="bar-bg"><div class="bar-fill" style="width: {{Sub_Conflict_Resolution}}%;"></div></div></div>
